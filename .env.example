# ═══════════════════════════════════════════════════════════════════════════════
# AffiliateAI — Environment Variables
# Copy file này thành .env.local và điền giá trị thực
# KHÔNG commit .env.local lên git
# ═══════════════════════════════════════════════════════════════════════════════

# ── APP ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
APP_URL=http://192.168.1.149:3000
API_URL=http://192.168.1.149:3001
LOG_LEVEL=info

# JWT secret — tạo bằng: openssl rand -hex 64
JWT_SECRET=change-this-to-a-random-64-char-hex-string

# ── SUPABASE ─────────────────────────────────────────────────────────────────
# Lấy từ: Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── AI MODELS — gọi trực tiếp API, không cần CakeAI ─────────────
# OpenAI: https://platform.openai.com/api-keys
# Dùng cho: Orchestrator, Evaluator, Social, Offer, Engage, RAG, Scheduler
OPENAI_API_KEY=sk-proj-...

# Anthropic: https://console.anthropic.com/api-keys  
# Dùng cho: Content Generator + Performance Analyst
ANTHROPIC_API_KEY=sk-ant-...

# ── OPENAI ───────────────────────────────────────────────────────────────────
# Dùng cho: Whisper (STT), GPT-4o Vision (image ranking), Embeddings
OPENAI_API_KEY=sk-proj-...
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_QUALITY=low
OPENAI_VIDEO_AGENT_MODEL=gpt-4o

# ── VISUAL AI ────────────────────────────────────────────────────────────────
# Remove.bg: https://www.remove.bg/api
REMOVEBG_API_KEY=...

# Replicate (Real-ESRGAN upscale): https://replicate.com
REPLICATE_API_TOKEN=r8_...

# FPT AI Voice (TTS tiếng Việt): https://fpt.ai/tts
FPT_AI_KEY=...
FPT_AI_VOICE=leminh
# Giọng khác: lannhi | myan | giahuy | linhsan

# ── AFFILIATE NETWORKS ───────────────────────────────────────────────────────

# Shopee Affiliate: https://affiliate.shopee.vn/open-api
SHOPEE_APP_ID=...
SHOPEE_SECRET=...
SHOPEE_AFFILIATE_URL=https://open-api.affiliate.shopee.vn

# Accesstrade: https://accesstrade.vn → My Account → API
ACCESSTRADE_TOKEN=...
ACCESSTRADE_BASE_URL=https://api.accesstrade.vn/v1

# TikTok Shop Affiliate: https://partner.tiktokshop.com
TIKTOK_APP_KEY=...
TIKTOK_APP_SECRET=...
TIKTOK_SHOP_URL=https://open-api.tiktokglobalshop.com

# Rentracks: https://rentracks.vn
RENTRACKS_KEY=...
RENTRACKS_BASE_URL=https://api.rentracks.vn

# Lazada Affiliate: https://lazada.vn/open-platform
LAZADA_APP_KEY=...
LAZADA_APP_SECRET=...

# ── SCHEDULER (Inngest) ───────────────────────────────────────────────────────
# https://www.inngest.com → Create App
INNGEST_EVENT_KEY=event_...
INNGEST_SIGNING_KEY=signkey_...

# ── CACHE (Upstash Redis) ─────────────────────────────────────────────────────
# https://console.upstash.com → Create Database
UPSTASH_REDIS_URL=https://...upstash.io
UPSTASH_REDIS_TOKEN=AX...

# ── PAYMENT ──────────────────────────────────────────────────────────────────

# ZaloPay: https://developers.zalopay.vn
ZALOPAY_APP_ID=...
ZALOPAY_KEY1=...
ZALOPAY_KEY2=...
ZALOPAY_CALLBACK_URL=https://api.yourdomain.vn/webhooks/zalopay
ZALOPAY_URL=https://sb-openapi.zalopay.vn/v2/create

# VNPAY
VNPAY_TMN_CODE=...
VNPAY_HASH_SECRET=...
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# ── MONITORING ────────────────────────────────────────────────────────────────
# Sentry: https://sentry.io
SENTRY_DSN=https://...@sentry.io/...

# PostHog: https://posthog.com
POSTHOG_KEY=phc_...
POSTHOG_HOST=https://app.posthog.com

# Slack alerts (optional)
SLACK_ALERT_WEBHOOK=https://hooks.slack.com/services/...
